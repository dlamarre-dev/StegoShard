{
  "name": "stegoshard",
  "version": "0.0.0",
  "private": true,
  "description": "Encrypt a file and encode it into robust, error-corrected images you can store anywhere: disk, paper, or the cloud.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "stegoshard": "dist-cli/stegoshard.js"
  },
  "files": [
    "dist-cli"
  ],
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "dev": "vite",
    "cli": "tsx src/cli/main.ts",
    "build": "tsc --noEmit && vite build",
    "build:cli": "tsc --noEmit && vite build --config vite.cli.config.ts",
    "package:cli": "deno compile --allow-read --allow-write --no-prompt --output stegoshard dist-cli/stegoshard.js",
    "build:firefox": "cross-env STEGOSHARD_TARGET=firefox vite build",
    "build:edge": "cross-env STEGOSHARD_TARGET=edge vite build",
    "build:store": "tsc --noEmit && vite build --mode store",
    "build:store:edge": "cross-env STEGOSHARD_TARGET=edge vite build --mode store",
    "build:store:firefox": "cross-env STEGOSHARD_TARGET=firefox vite build --mode store",
    "build:web": "tsc --noEmit && vite build --config vite.web.config.ts",
    "dev:web": "vite --config vite.web.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "fixtures": "tsx scripts/gen-fixtures.ts",
    "vectors": "tsx scripts/gen-vectors.ts",
    "icons": "tsx scripts/gen-icons.ts",
    "package": "npm run build:store && npm run build:store:edge && npm run build:store:firefox && tsx scripts/package.ts"
  },
  "dependencies": {
    "fflate": "^0.8.3",
    "hash-wasm": "^4.12.0",
    "jsqr": "^1.4.0",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@pdf-lib/fontkit": "^1.1.1",
    "@types/chrome": "^0.0.287",
    "@types/node": "^22.20.1",
    "@types/pngjs": "^6.0.5",
    "@types/qrcode": "^1.5.6",
    "@types/webextension-polyfill": "^0.12.1",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^3.2.7",
    "cross-env": "^7.0.3",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "fast-png": "^8.0.0",
    "globals": "^17.7.0",
    "jpeg-js": "^0.4.4",
    "pngjs": "^7.0.0",
    "prettier": "^3.4.2",
    "tsx": "^4.23.1",
    "typescript": "^5.7.2",
    "vite": "^7.3.6",
    "vitest": "^3.2.7"
  }
}
